# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this applet is hosted (optional, configured automatically in production).
# APP_URL=http://localhost:5173

# OPENWEATHER_API_KEY: Optional. Fetches real weather forecasts and precipitation data.
OPENWEATHER_API_KEY=your_openweather_api_key_here

# DATAGOVIN_API_KEY: Optional. Fetches live mandi market prices.
DATAGOVIN_API_KEY=your_datagovin_api_key_here

# NEON_DATABASE_URL: Used for Postgres backend integration.
NEON_DATABASE_URL=postgresql://username:password@host/database?sslmode=require
